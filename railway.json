{
  "deploy": {
    "command": "echo 'loldata-cron ready' && sleep infinity"
  },
  "crons": [
    {
      "schedule": "0 */4 * * *",
      "command": "bun run src/jobs/sync-cdn.ts"
    },
    {
      "schedule": "0 */2 * * *",
      "command": "bun run src/jobs/update-stats.ts"
    },
    {
      "schedule": "0 3 * * *",
      "command": "bun run src/jobs/ingest-ladder.ts"
    },
    {
      "schedule": "0 4 * * *",
      "command": "bun run src/jobs/track-ranks.ts"
    },
    {
      "schedule": "30 4 * * *",
      "command": "bun run src/jobs/backfill-timelines.ts"
    },
    {
      "schedule": "0 5 * * *",
      "command": "bun run src/jobs/snapshot-champion-stats.ts"
    }
  ]
}
