{
  "deploy": {
    "command": "python main.py"
  },
  "crons": [
    {
      "schedule": "*/10 * * * *",
      "command": "python -u main.py --no-ingest --also-process-users"
    },
    {
      "schedule": "0 3 * * *",
      "command": "bun run src/index.ts"
    },
    {
      "schedule": "0 */4 * * *",
      "command": "bun run src/jobs/sync-cdn.ts"
    }
  ]
}
